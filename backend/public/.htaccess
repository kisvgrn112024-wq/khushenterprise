<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Block direct access to .txt next data files
  RewriteRule \.txt$ - [F,L]

  # 1. Skip rewrites for actual existing files (CSS, JS, images, fonts, etc.)
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # 2. Skip rewrites for actual existing directories
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3. If path.html exists on disk, serve it (handles /admin-portal-ke, /secure-portal-access, etc.)
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # 4. Handle trailing slash: /admin-portal-ke/ -> /admin-portal-ke.html
  RewriteCond %{REQUEST_URI} ^/(.+)/$
  RewriteCond %{DOCUMENT_ROOT}/%1.html -f
  RewriteRule ^(.+)/$ $1.html [L]

  # 5. Handle nested paths: /admin-portal-ke/products -> /admin-portal-ke/products.html
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
  RewriteRule ^(.+)$ $1.html [L]

  # 6. Final fallback: serve index.html for any unmatched route (SPA client-side routing)
  RewriteRule ^ /index.html [L]
</IfModule>

# Custom error pages
ErrorDocument 404 /404.html
ErrorDocument 403 /404.html

# Performance & Security Headers
<IfModule mod_headers.c>
  # Cache static assets for 1 year
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # No cache for HTML files (always fetch fresh)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
